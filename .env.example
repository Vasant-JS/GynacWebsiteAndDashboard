PORT=5177
SESSION_SECRET=change-this-dev-secret

# Supabase/Postgres:
# Copy the Session Pooler URI from Supabase Dashboard > Connect.
# Use Session Pooler for local IPv4 development unless your network supports direct IPv6.
# Example:
# DATABASE_URL=postgres://postgres.PROJECT_REF:PASSWORD@aws-REGION.pooler.supabase.com:5432/postgres
# PGSSLMODE=require
# PGSSL_REJECT_UNAUTHORIZED=false

PGHOST=localhost
PGPORT=5432
PGUSER=postgres
PGPASSWORD=postgres
PGDATABASE=femmecare

USE_PG_SESSION=false

# Future Google Meet integration
GOOGLE_CALENDAR_ACCESS_TOKEN=
GOOGLE_CALENDAR_ID=primary

# Future WhatsApp integration
WHATSAPP_PROVIDER=
WHATSAPP_API_TOKEN=
